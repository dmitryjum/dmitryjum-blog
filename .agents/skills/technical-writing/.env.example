# Technical writing skill configuration
# Copy these to your shell profile (~/.zshrc, ~/.bashrc, etc.) if you want to override defaults

# Title Casing Style
# Options: "sentence" (default) or "title"
# Sentence case: "Why I stopped using feature flags"
# Title case: "Why I Stopped Using Feature Flags"
export TITLE_CASE_STYLE="sentence"

# Heading Casing Style
# Options: "sentence" (default) or "title"
# Sentence case: "How we built it"
# Title case: "How We Built It"
export HEADING_CASE_STYLE="sentence"
